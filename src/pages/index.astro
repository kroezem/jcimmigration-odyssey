---
import { Icon } from 'astro-icon/components';
import {
	Button,
	CustomerQuoteSection,
	ThreeColumnTextSection,
	CtaCardSection,
} from '@components/odyssey-theme';

import Layout from '../layouts/Page.astro';
import TextAndImageHero from '../components/sections/heros/TextAndImageHero.astro';

const seo = {
	title: 'JC Immigration',
	description:
		'Trusted Canadian immigration legal consultancy — family sponsorship, Express Entry, and temporary permits.',
};
---

<Layout {seo}>
	<TextAndImageHero>
		<div slot="text-container">
			<h1>Your Path to Canada Starts Here</h1>
			<p>
				JC Immigration has guided families, workers, and students through the
				Canadian immigration process for over 15 years. We know this journey
				personally — and we'll be with you every step of the way.
			</p>
		</div>
		<div slot="btns-container">
			<Button href="/theme/get-started" customIcon
				>Book a Consultation <Fragment slot="icon">
					<Icon name="ic:baseline-chevron-right" />
				</Fragment></Button
			>
		</div>
		<picture slot="image-container">
			<img
				src="/assets/images/home/classic-hero.jpg"
				alt="Astro Odyssey"
				id="home-hero-image"
			/>
		</picture>
	</TextAndImageHero>

	<ThreeColumnTextSection>
		<div slot="column-1-body">
			<h2>Family Sponsorship</h2>
			<p>
				Reunite with your spouse, common-law partner, or parents. We handle the
				paperwork and submissions so you can focus on what matters.
			</p>
		</div>
		<Button slot="column-1-cta">Book a Consultation</Button>
		<div slot="column-2-body">
			<h2>Express Entry</h2>
			<p>
				Exploring permanent residency? Our team will assess your profile and
				guide you through the federal skilled worker, CEC, and PNP streams.
			</p>
		</div>
		<Button slot="column-2-cta" outlined>Book a Consultation</Button>
		<div slot="column-3-body">
			<h2>Work, Study & Visit</h2>
			<p>
				Whether you need a work permit, student visa, or visitor authorization,
				we'll ensure your application is complete and compelling.
			</p>
		</div>
		<Button slot="column-3-cta">Book a Consultation</Button>
	</ThreeColumnTextSection>

	<CustomerQuoteSection
		quoteText="The team at JC Immigration made an overwhelming process feel manageable. They were thorough, responsive, and genuinely cared about our outcome."
		customerName="Satisfied Client"
	/>

	<CtaCardSection
		background="var(--theme-surface-2)"
		color="var(--theme-on-surface-2)"
	>
		<h2>Ready to Start Your Immigration Journey?</h2>
		<p>
			Book a consultation today and get clear, honest guidance from a team that
			has been through the process themselves.
		</p>
		<Button href="/theme/get-started" customIcon
			>Book a Consultation <Fragment slot="icon">
				<Icon name="ic:baseline-chevron-right" />
			</Fragment></Button
		>
	</CtaCardSection>
</Layout>
