---
import { Button, Container, TextCardSection } from '@components/odyssey-theme';
import Layout from '../../layouts/Page.astro';

const seo = {
	title: 'Consultation | SC Immigration Law',
	description: 'Book a consultation with SC Immigration Law.',
};
---

<Layout {seo}>
	<Container>
		<TextCardSection>
			<h1>Book a Consultation</h1>
			<p>
				This demo route now points visitors toward SC Immigration Law's consultation
				process.
			</p>
			<div class="cta-buttons__container">
				<Button href="/company/contact">Contact SC Immigration Law</Button>
			</div>
		</TextCardSection>
	</Container>
</Layout>

<style>
	.cta-buttons__container {
		display: flex;
		flex-wrap: wrap;
	}

	.cta-buttons__container :global(a) {
		margin-right: 1rem;
		margin-bottom: 1rem;
	}
</style>
