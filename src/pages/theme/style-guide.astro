---
import { Button, Container, TextCardSection } from '@components/odyssey-theme';
import Layout from '../../layouts/Page.astro';

const seo = {
	title: 'Service Guide | SC Immigration Law',
	description: 'Canadian immigration service guidance from SC Immigration Law.',
};
---

<Layout {seo}>
	<Container>
		<TextCardSection>
			<h1>Service Guide</h1>
			<p>
				SC Immigration Law supports family sponsorship, Express Entry, work and
				study permits, visitor visas, and complete application preparation.
			</p>
			<Button href="/company/contact">Book a Consultation</Button>
		</TextCardSection>
	</Container>
</Layout>
