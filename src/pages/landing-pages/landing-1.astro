---
import { Icon } from 'astro-icon/components';
import {
	AnnouncementBar,
	Button,
	CustomerQuoteSection,
	ThreeColumnTextSection,
	YouTubeEmbedSection,
	StickyTextImageSection,
	CtaCardSection,
} from '@components/odyssey-theme';
import Layout from '../../layouts/Page.astro';
import TextAndImageHero from '../../components/sections/heros/TextAndImageHero.astro';

const seo = {
	title: 'Immigration Services | JC Immigration',
	description: 'Canadian immigration support for families, workers, students, and visitors.',
};
---

<AnnouncementBar
	text="Read Our Latest Immigration Update"
	href="/blog/posts/remote-work-mental-health/"
	slot="announcement-bar"
/>
<Layout {seo}>
	<TextAndImageHero reversed>
		<div slot="text-container">
			<h1>Clear Guidance for Your Canadian Immigration Journey</h1>
			<p>
				Work with a warm, experienced team that prepares your application with
				care from consultation to submission.
			</p>
		</div>
		<div slot="btns-container">
			<Button href="/company/contact" customIcon
				>Book a Consultation <Fragment slot="icon">
					<Icon name="ic:baseline-chevron-right" />
				</Fragment></Button
			>
		</div>
		<picture slot="image-container">
			<img
				src="/assets/images/landing-1/landing-hero-1.jpg"
				alt="Consultation notes on a desk"
				id="home-hero-image"
			/>
		</picture>
	</TextAndImageHero>

	<CustomerQuoteSection
		quoteText="JC Immigration helped us understand every document, deadline, and next step. We felt prepared and supported throughout."
		customerName="Satisfied Client"
	/>

	<ThreeColumnTextSection>
		<div slot="column-1-body">
			<h2>Family Sponsorship</h2>
			<p>
				Bring your spouse, common-law partner, parents, or loved ones closer
				with organized, complete sponsorship support.
			</p>
		</div>
		<Button slot="column-1-cta" href="/company/contact">Book a Consultation</Button>
		<div slot="column-2-body">
			<h2>Express Entry</h2>
			<p>
				Understand your eligibility, strengthen your profile, and move through
				permanent residence pathways with practical guidance.
			</p>
		</div>
		<Button slot="column-2-cta" href="/company/contact">Book a Consultation</Button>
		<div slot="column-3-body">
			<h2>Work, Study & Visit</h2>
			<p>
				Prepare temporary permit and visitor applications with the right
				supporting documents and a clear plan.
			</p>
		</div>
		<Button slot="column-3-cta" href="/company/contact">Book a Consultation</Button>
	</ThreeColumnTextSection>

	<YouTubeEmbedSection url="https://www.youtube.com/watch?v=cbYr75_R15M" rounded
	/>

	<StickyTextImageSection>
		<div slot="text-container">
			<h2>How We Help</h2>
			<h3>Assess</h3>
			<p>
				We review your goals, background, timelines, and options before
				recommending a path forward.
			</p>
			<h3>Prepare</h3>
			<p>
				Our team helps gather documents, identify gaps, and prepare clear
				submissions for immigration officers.
			</p>
			<h3>Submit</h3>
			<p>
				We keep your application organized, track status updates, and explain
				next steps as your file moves forward.
			</p>
		</div>
		<picture slot="image-container">
			<img
				src="/assets/images/landing-1/landing-sticky.jpg"
				alt="Immigration planning materials"
				loading="lazy"
			/>
		</picture>
	</StickyTextImageSection>

	<CtaCardSection
		background="var(--theme-surface-2)"
		color="var(--theme-on-surface-2)"
	>
		<h2>Ready to Start Your Immigration Journey?</h2>
		<p>
			Book a consultation and get clear, honest guidance from a team that knows
			the Canadian immigration process personally.
		</p>
		<Button href="/company/contact" customIcon
			>Book a Consultation <Fragment slot="icon">
				<Icon name="ic:baseline-chevron-right" />
			</Fragment></Button
		>
	</CtaCardSection>
</Layout>
