---
import { TextSection } from '@components/odyssey-theme';
import Layout from '../../layouts/Page.astro';
import HeroSection from '../../components/sections/heros/HeroSection.astro';

const seo = {
	title: 'About | JC Immigration',
	description: 'About JC Immigration',
};
---

<Layout {seo}>
	<HeroSection>
		<div slot="text-container">
			<h1>About JC Immigration</h1>
			<p>
				JC Immigration is a Canadian immigration legal consultancy with over 15
				years of experience. What sets us apart is simple: our staff have
				personally navigated the Canadian immigration system. We know what the
				process feels like from the inside, and we bring that perspective to
				every client we serve.
			</p>
		</div>
		<picture slot="image-container">
			<img
				src="/assets/images/home/jc-about.jpg"
				alt="The JC Immigration team in consultation"
				id="home-hero-image"
			/>
		</picture>
	</HeroSection>
	<TextSection narrow>
		<p>
			We are a small, approachable, and dedicated team committed to the highest
			standard of service. We pride ourselves on efficient turnaround times and
			clear, honest communication with every client.
		</p>
		<p>
			From family sponsorships to permanent residence pathways and temporary
			permits, our role is to make each step clearer, calmer, and better
			prepared.
		</p>

		<p>
			Every application is different, so we take time to understand your
			circumstances, explain your options, and help you move forward with
			practical advice.
		</p>
		<p>
			When you are ready to begin, our team can help you gather the right
			documents, prepare strong submissions, and stay organized from
			consultation to decision.
		</p>
	</TextSection>
</Layout>
